# 📝 CONFIGURACIÓN DE FARMAAVISA
# Este es tu "bloc de notas". Completá los datos después del signo =
# Si no tenés el dato todavía, podés dejarlo vacío.

# 📧 Email de contacto para el servicio de notificaciones
CONTACT_EMAIL="admin@farmaciademia.com"

# 🔑 Datos de acceso para el PANEL DE CONTROL
# Estas son las credenciales iniciales. Podés cambiarlas luego.
ADMIN_EMAIL="admin@farmaciademia.com"
ADMIN_PASSWORD_INITIAL="farmacia2024"

# 🛡️ Pregunta de seguridad (para recuperar tu clave si la olvidás)
SECRET_QUESTION="¿Cuál es el nombre de tu primera mascota?"
SECRET_ANSWER="mascota"

# 🔔 LLAVES VAPID (Para que funcionen las notificaciones Push)
# El sistema las genera solo si las dejás vacías, pero si tenés
# unas específicas de otro proyecto, las pegás acá.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# 🌐 URL del Proyecto (Ej: la de Railway)
# Si estás testeando, podés dejarla vacía y el sistema usará la actual.
PROJECT_URL=
